{
  "name": "jude-tf",
  "version": "0.0.0-alpha",
  "description": "TensorFlow C API bindings for Node.js — zero-copy inference via jude-map",
  "main":  "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type":  "module",
  "files": [
    "dist",
    "prebuilds",
    "src/native",
    "binding.gyp",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build:ts":     "tsc",
    "build:native": "node-gyp rebuild",
    "build":        "npm run build:ts && npm run build:native",
    "test":         "node scripts/test.js",
    "test:clean":   "node -e \"require('fs').rmSync('./test/test.db', { force: true })\" && npm test",
    "test:install": "node scripts/test-install.js"
  },
  "binary": {
    "napi_versions": [
      8
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "tensorflow",
    "inference",
    "native addon",
    "zero-copy",
    "mmap",
    "jude-map"
  ],
  "author": "Alan Kochukalam George",
  "license": "Apache-2.0",
  "peerDependencies": {
    "jude-map": ">=0.0.0-alpha"
  },
  "dependencies": {
    "node-addon-api":  "^8.6.0",
    "node-gyp-build":  "^4.8.4"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx":         "^4.0.0",
    "typescript":  "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/A-KGeorge/jude-map.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  }
}