{
  "name": "jude-tf",
  "version": "0.0.1",
  "description": "TensorFlow C API bindings for Node.js — zero-copy inference via jude-map",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "prebuilds",
    "src/native",
    "binding.gyp",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build:ts": "tsc",
    "build:native": "node-gyp rebuild",
    "build": "npm run build:ts && npm run build:native",
    "test": "node scripts/test.mjs",
    "test:clean": "node -e \"require('fs').rmSync('./test/test.db', { force: true })\" && npm test",
    "test:install": "node scripts/test-install.js",
    "prebuildify": "prebuildify --napi --strip --target 18.0.0 --target 20.0.0 --target 22.0.0 --target 24.0.0",
    "changeset": "changeset",
    "version": "changeset version",
    "publish-packages": "changeset publish"
  },
  "binary": {
    "napi_versions": [
      8
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "tensorflow",
    "inference",
    "native addon",
    "zero-copy",
    "mmap",
    "jude-map"
  ],
  "author": "Alan Kochukalam George",
  "license": "Apache-2.0",
  "peerDependencies": {
    "jude-map": ">=0.1.0"
  },
  "dependencies": {
    "node-addon-api": "^8.6.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "prebuildify": "^6.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/A-KGeorge/jude.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  }
}